# ── DeepSeek API ──────────────────────────────────────────────────────────────
# Get your key from: https://platform.deepseek.com
DEEPSEEK_API_KEY=

# ── WeChat ilink delivery ─────────────────────────────────────────────────────
# Your ilink auth token (from the wechat-claude-code setup)
ILINK_TOKEN=

# Target WeChat user UID to receive digests
WECHAT_UID=

# ── Optional: GitHub token for Anthropic org repo fetching ───────────────────
# Without this, public repos are still accessible but rate-limited (60 req/hr)
GITHUB_TOKEN=

# ── Optional: model overrides ────────────────────────────────────────────────
# Default: deepseek-chat (fast/batch), deepseek-reasoner (deep analysis)
# SUMMARIZE_MODEL=deepseek-chat
# ANALYZE_MODEL=deepseek-reasoner
