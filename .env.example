# ── MiniMax API ───────────────────────────────────────────────────────────────
# Get your key from: https://platform.minimaxi.com  (Anthropic-compatible endpoint)
MINIMAX_API_KEY=

# ── Agnes image API (evening 小黑 illustrations) ──────────────────────────────
# Get your key from https://agnes-ai.com  (OpenAI-compatible image endpoint)
AGNES_API_KEY=
# Optional model override; default: agnes-image-2.1-flash
# AGNES_IMAGE_MODEL=agnes-image-2.1-flash

# ── WeChat ilink delivery ─────────────────────────────────────────────────────
# Your ilink auth token (from the wechat-claude-code setup)
ILINK_TOKEN=

# Target WeChat user UID to receive digests
WECHAT_UID=

# ── Optional: GitHub token for Anthropic org repo fetching ───────────────────
# Without this, public repos are still accessible but rate-limited (60 req/hr)
GITHUB_TOKEN=

# ── Optional: model override ─────────────────────────────────────────────────
# All generation (scoring, enrichment, insight, lead article) runs on this model.
# Default: MiniMax-M3
# SUMMARIZE_MODEL=MiniMax-M3
