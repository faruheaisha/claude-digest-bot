<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
<meta name="color-scheme" content="light dark">
<title>AI 日报 · {{ date_str }} {{ mode_label }}</title>
<style>
/* ── 设计令牌 ──────────────────────────────────────────────── */
:root {
  --bg:           #FAF9F7;
  --bg-surface:   #F2F0ED;
  --bg-insight:   #FEF6F0;
  --text-primary: #1A1614;
  --text-body:    #3D3833;
  --text-muted:   #9B9591;
  --border:       #E8E5E1;
  --border-light: #F0EDE9;

  --claude:  #CC785C;
  --cn:      #C8201A;
  --global:  #1D50B4;

  --f-display: "PingFang SC", "Noto Serif CJK SC", "Source Han Serif SC",
               "Songti SC", Georgia, "Times New Roman", serif;
  --f-body:    -apple-system, "PingFang SC", "Hiragino Sans GB",
               "Microsoft YaHei UI", "Noto Sans CJK SC", sans-serif;
  --f-mono:    "SF Mono", "Cascadia Mono", "Consolas",
               "Courier New", monospace;

  --radius:  3px;
  --shadow:  0 1px 3px rgba(0,0,0,.06);
}

@media (prefers-color-scheme: dark) {
  :root {
    --bg:           #171412;
    --bg-surface:   #201D1A;
    --bg-insight:   #221A16;
    --text-primary: #F2EDE8;
    --text-body:    #C5BDB6;
    --text-muted:   #6E6760;
    --border:       #2C2824;
    --border-light: #252220;

    --claude:  #E0916E;
    --cn:      #F47270;
    --global:  #6EA0E8;
  }
}

/* ── 基础重置 ──────────────────────────────────────────────── */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

body {
  background: var(--bg);
  color: var(--text-primary);
  font-family: var(--f-body);
  font-size: 15px;
  line-height: 1.75;
  -webkit-font-smoothing: antialiased;
  word-break: break-word;
  overflow-x: hidden;
}

a { color: inherit; }

/* ── 页面容器 ──────────────────────────────────────────────── */
.page {
  max-width: 800px;
  margin: 0 auto;
  padding-bottom: 56px;
}

/* ── 头部 ──────────────────────────────────────────────────── */
.dh {
  padding: 28px 22px 22px;
  border-bottom: 1px solid var(--border);
}

.dh__eyebrow {
  display: flex;
  align-items: center;
  gap: 10px;
  margin-bottom: 10px;
}

.dh__date {
  font-family: var(--f-mono);
  font-size: 11px;
  letter-spacing: 0.1em;
  color: var(--text-muted);
  text-transform: uppercase;
}

.dh__badge {
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.08em;
  padding: 2px 8px 2px 7px;
  border-radius: var(--radius);
  background: var(--claude);
  color: #fff;
}

.dh__title {
  font-family: var(--f-display);
  font-size: 28px;
  font-weight: 700;
  line-height: 1.2;
  letter-spacing: -.02em;
  color: var(--text-primary);
}

.dh__sub {
  margin-top: 5px;
  font-size: 12px;
  color: var(--text-muted);
  letter-spacing: .03em;
}

/* ── 今日洞察 ──────────────────────────────────────────────── */
.insight {
  margin: 20px 22px 0;
  padding: 20px 20px 20px 18px;
  background: var(--bg-insight);
  border-left: 3px solid var(--claude);
  position: relative;
}

.insight::before {
  content: '';
  position: absolute;
  top: 0; right: 0; bottom: 0; left: 0;
  background: var(--bg-insight);
  z-index: -1;
}

.insight__label {
  font-size: 10px;
  font-weight: 700;
  letter-spacing: .14em;
  text-transform: uppercase;
  color: var(--claude);
  margin-bottom: 10px;
  font-family: var(--f-body);
}

.insight__text {
  font-family: var(--f-display);
  font-size: 15.5px;
  line-height: 1.85;
  color: var(--text-body);
  font-style: normal;
}

/* ── 专区通用 ──────────────────────────────────────────────── */
.zone {
  margin-top: 28px;
}

.zone__head {
  display: flex;
  align-items: center;
  gap: 0;
  padding: 0 22px 10px;
  border-bottom: 1.5px solid var(--zone-color);
}

.zone__name {
  font-family: var(--f-display);
  font-size: 13px;
  font-weight: 700;
  letter-spacing: .04em;
  color: var(--zone-color);
}

.zone__count {
  margin-left: auto;
  font-size: 11px;
  color: var(--text-muted);
  font-family: var(--f-mono);
}

.zone--claude { --zone-color: var(--claude); }
.zone--cn     { --zone-color: var(--cn); }
.zone--global { --zone-color: var(--global); }

.zone__articles {
  padding: 0 22px;
}

.zone__empty {
  padding: 18px 0 4px;
  font-size: 13px;
  color: var(--text-muted);
  font-style: italic;
}

/* ── 文章卡片 ──────────────────────────────────────────────── */
.ac {
  padding: 20px 0 18px;
  border-bottom: 1px solid var(--border-light);
}

.ac:last-child { border-bottom: none; }

.ac__head {
  display: flex;
  align-items: baseline;
  gap: 8px;
  margin-bottom: 12px;
}

.ac__imp {
  flex-shrink: 0;
  font-size: 12px;
  letter-spacing: -.04em;
  line-height: 1.4;
  white-space: nowrap;
  color: var(--text-primary);
}

.ac__title {
  flex: 1;
  min-width: 0;
  font-family: var(--f-display);
  font-size: 15.5px;
  font-weight: 600;
  line-height: 1.5;
  color: var(--text-primary);
  text-decoration: none;
  text-wrap: pretty;
  transition: opacity .15s;
}

.ac__figure {
  margin: 0 0 12px;
}

.ac__cover {
  display: block;
  width: 100%;
  max-height: 200px;
  object-fit: cover;
  border-radius: 8px;
  border: 1px solid var(--border-light);
}

.ac__date {
  margin-top: 6px;
  font-size: 11px;
  font-family: var(--f-mono);
  color: var(--text-muted);
  letter-spacing: .02em;
}

.ac__date--solo {
  margin: 0 0 12px;
}

/* 关键句：accent 色、稍大、强调 */
.ac__points {
  list-style: none;
  margin: 0 0 12px;
  padding: 12px 14px;
  background: oklch(from var(--claude) l c h / .05);
  border-left: 3px solid var(--claude);
  border-radius: 0 6px 6px 0;
}

.ac__points li {
  position: relative;
  padding-left: 16px;
  font-size: 13.5px;
  font-weight: 600;
  line-height: 1.65;
  color: var(--text-primary);
  margin-bottom: 6px;
}

.ac__points li:last-child { margin-bottom: 0; }

.ac__points li::before {
  content: "";
  position: absolute;
  left: 2px;
  top: .62em;
  width: 5px;
  height: 5px;
  background: var(--claude);
  border-radius: 50%;
}

.ac__title:active { opacity: .65; }

/* 在支持 hover 的设备上才显示 hover 效果 */
@media (hover: hover) {
  .ac__title:hover { color: var(--zone-color, var(--claude)); }
}

.ac__summary {
  font-size: 13px;
  line-height: 1.85;
  color: var(--text-body);
  margin-bottom: 12px;
  white-space: pre-line;
  letter-spacing: .01em;
}

.ac__meta {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
  align-items: center;
}

.ac__source {
  display: inline-block;
  padding: 1px 6px;
  font-size: 10.5px;
  font-family: var(--f-mono);
  color: var(--text-muted);
  background: var(--bg-surface);
  border: 1px solid var(--border);
  border-radius: 2px;
  white-space: nowrap;
}

.ac__tag {
  display: inline-block;
  padding: 1px 7px;
  font-size: 10px;
  font-weight: 600;
  border-radius: 10px;
  color: #fff;
  white-space: nowrap;
  letter-spacing: .02em;
}

/* ── 温故知新 ──────────────────────────────────────────────── */
.lookback {
  margin: 36px 22px 0;
  padding-top: 22px;
  border-top: 1px solid var(--border);
}

.lookback__label {
  font-size: 10px;
  font-weight: 700;
  letter-spacing: .14em;
  text-transform: uppercase;
  color: var(--text-muted);
  margin-bottom: 10px;
}

.lookback__card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 13px 15px;
  background: var(--bg-surface);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  text-decoration: none;
  color: var(--text-body);
  font-size: 13px;
  gap: 10px;
  transition: border-color .15s;
}

@media (hover: hover) {
  .lookback__card:hover {
    border-color: var(--claude);
    color: var(--text-primary);
  }
}

.lookback__card::after {
  content: '→';
  color: var(--text-muted);
  flex-shrink: 0;
  font-size: 14px;
}

/* ── 页脚 ──────────────────────────────────────────────────── */
.footer {
  margin-top: 40px;
  padding: 18px 22px 0;
  border-top: 1px solid var(--border);
  display: flex;
  justify-content: space-between;
  align-items: center;
  flex-wrap: wrap;
  gap: 8px;
}

.footer__text {
  font-size: 11px;
  font-family: var(--f-mono);
  color: var(--text-muted);
  letter-spacing: .04em;
}

.footer__link {
  font-size: 11px;
  font-family: var(--f-mono);
  color: var(--claude);
  text-decoration: none;
  letter-spacing: .04em;
}

@media (hover: hover) {
  .footer__link:hover { text-decoration: underline; }
}

/* ── 响应式微调 ────────────────────────────────────────────── */
@media (max-width: 480px) {
  .dh__title { font-size: 24px; }
  .insight__text { font-size: 14.5px; }
  .ac__title { font-size: 14px; }
}

/* ── 主文章（晚报） ───────────────────────────────────────── */
.lead {
  margin: 24px 0 0;
  padding: 32px 24px 28px;
  background: var(--bg-surface);
  border-top: 3px solid var(--claude);
  border-bottom: 1px solid var(--border);
}

.lead__badge {
  display: inline-flex;
  align-items: center;
  gap: 5px;
  font-size: 11px;
  font-weight: 600;
  letter-spacing: .08em;
  text-transform: uppercase;
  color: var(--claude);
  margin-bottom: 16px;
}

.lead__badge::before {
  content: ;
  display: inline-block;
  width: 6px;
  height: 6px;
  background: var(--claude);
  border-radius: 50%;
}

.lead__title {
  font-family: var(--f-display);
  font-size: 24px;
  font-weight: 800;
  line-height: 1.3;
  letter-spacing: -.03em;
  color: var(--text-primary);
  margin-bottom: 20px;
  text-wrap: pretty;
  border-left: 4px solid var(--claude);
  padding-left: 14px;
}

.lead__body {
  font-size: 15px;
  line-height: 1.85;
  color: var(--text-body);
  font-family: var(--f-display);
}

/* ── 长文内部元素样式 ──────────────────────────────────────── */
.lead__body .la-h2 {
  font-family: var(--f-display);
  font-size: 18.5px;
  font-weight: 700;
  color: var(--text-primary);
  margin: 44px 0 14px;
  padding-bottom: 9px;
  border-bottom: 2px solid var(--claude);
  letter-spacing: -.01em;
  line-height: 1.4;
}

.lead__body .la-h3 {
  font-family: var(--f-display);
  font-size: 15.5px;
  font-weight: 600;
  color: var(--text-primary);
  margin: 30px 0 10px;
  padding-left: 10px;
  border-left: 3px solid var(--claude);
  line-height: 1.45;
}

.lead__body .la-p {
  margin: 0 0 20px;
  text-indent: 2em;
  hyphens: auto;
}

.lead__body .la-p:first-child {
  text-indent: 0;
  font-size: 15.5px;
  font-weight: 500;
  color: var(--text-primary);
}

.lead__body .la-hr {
  border: none;
  border-top: 1px dashed var(--border);
  margin: 30px 0;
}

/* 金句 pull-quote：醒目、交替背景凸显 */
.lead__body .la-quote {
  position: relative;
  margin: 22px 0;
  padding: 16px 18px 16px 44px;
  background: oklch(from var(--claude) l c h / .08);
  border-left: 4px solid var(--claude);
  border-radius: 0 8px 8px 0;
  font-family: var(--f-display);
  font-style: normal;
  font-weight: 600;
  font-size: 15.5px;
  line-height: 1.7;
  color: var(--text-primary);
  text-indent: 0;
}

.lead__body .la-quote::before {
  content: "\201C";
  position: absolute;
  left: 12px;
  top: 6px;
  font-family: Georgia, serif;
  font-size: 34px;
  line-height: 1;
  color: var(--claude);
  opacity: .55;
}

/* 偶数金句换一种背景色，形成节奏变化 */
.lead__body .la-quote:nth-of-type(even) {
  background: oklch(from var(--text-primary) l c h / .05);
  border-left-color: var(--text-secondary);
}

.lead__body .la-quote:nth-of-type(even)::before {
  color: var(--text-secondary);
}

.lead__body .la-list {
  margin: 10px 0 16px 1.2em;
  padding: 0;
}

.lead__body .la-list li {
  margin-bottom: 7px;
  line-height: 1.75;
  position: relative;
}

.lead__body .la-list li::marker {
  color: var(--claude);
}

.lead__body strong {
  font-weight: 700;
  color: var(--text-primary);
}

.lead__body em {
  font-style: italic;
  color: var(--text-secondary);
}

.lead__body .la-code {
  font-family: ui-monospace, monospace;
  font-size: 13px;
  background: var(--bg-surface);
  color: #e85d75;
  padding: 1px 5px;
  border-radius: 3px;
  border: 1px solid var(--border);
}

.lead__body .la-link {
  color: var(--claude);
  text-decoration: underline;
  text-decoration-thickness: 1px;
  text-underline-offset: 2px;
  transition: opacity .15s;
}

.lead__body .la-link:hover {
  opacity: .7;
}

/* 深度文章插图 + 图注 */
.lead__body .la-figure {
  margin: 22px 0;
}

.lead__body .la-img {
  display: block;
  width: 100%;
  max-height: 280px;
  object-fit: cover;
  border-radius: 10px;
  border: 1px solid var(--border-light);
}

.lead__body .la-cap {
  margin-top: 8px;
  font-size: 12px;
  font-family: var(--f-mono);
  color: var(--text-muted);
  text-align: center;
  letter-spacing: .02em;
  padding: 0 8px;
}

/* 首段做成导语样式：左侧粗线 + 大字 */
.lead__body .la-p:first-of-type {
  border-left: 3px solid var(--claude);
  padding-left: 14px;
  margin-left: -2px;
}

</style>
</head>
<body>
<div class="page">

  <!-- ▸ 头部 -->
  <header class="dh">
    <div class="dh__eyebrow">
      <span class="dh__date">{{ date_str }}</span>
      <span class="dh__badge">{{ mode_label }}</span>
    </div>
    <h1 class="dh__title">AI 日报</h1>
    <p class="dh__sub">Claude · Anthropic · 国内外 AI 动态 · 每日精选</p>
  </header>

  <!-- ▸ 今日洞察 -->
  <section class="insight">
    <div class="insight__label">今日洞察</div>
    <p class="insight__text">{{ insight }}</p>
  </section>


  <!-- ▸ 深度文章（晚报专属） -->
  {% if lead_article %}
  <section class=lead>
    <div class=lead__badge>深度 · 今日主题</div>
    <h2 class=lead__title>{{ lead_article.title }}</h2>
    <div class=lead__body>{{ lead_article.body|safe }}</div>
  </section>
  {% endif %}

  <!-- ▸ 专区一：Claude / Anthropic -->
  <section class="zone zone--claude">
    <div class="zone__head">
      <span class="zone__name">Claude / Anthropic</span>
      {% if claude_articles %}
      <span class="zone__count">{{ claude_articles | length }} 条</span>
      {% endif %}
    </div>
    <div class="zone__articles">
      {% if claude_articles %}
        {% for article in claude_articles %}
        <div class="ac">
          <div class="ac__head">
            <span class="ac__imp">{{ article.importance_icon }}</span>
            <a class="ac__title" href="{{ article.url }}" target="_blank" rel="noopener noreferrer">{{ article.title }}</a>
          </div>
          {% if article.og_image %}
          <figure class="ac__figure">
            <img class="ac__cover" src="{{ article.og_image }}" alt="" loading="lazy" onerror="this.parentNode.style.display='none'">
            <figcaption class="ac__date">{{ article.pub_date_str or "发布日期未知" }}</figcaption>
          </figure>
          {% else %}
          <div class="ac__date ac__date--solo">{{ article.pub_date_str or "发布日期未知" }}</div>
          {% endif %}
          {% if article.key_points %}
          <ul class="ac__points">
            {% for p in article.key_points %}<li>{{ p }}</li>{% endfor %}
          </ul>
          {% endif %}
          {% if article.ai_summary %}<p class="ac__summary">{{ article.ai_summary }}</p>{% endif %}
          <div class="ac__meta">
            <span class="ac__source">{{ article.source }}</span>
            {% for tag in article.tags %}{% if tag in article._link_colors %}<span class="ac__tag" style="background:{{ article._link_colors[tag] }}">{{ tag }}</span>{% endif %}{% endfor %}
          </div>
        </div>
        {% endfor %}
      {% else %}
        <p class="zone__empty">暂无 Claude / Anthropic 相关动态</p>
      {% endif %}
    </div>
  </section>

  <!-- ▸ 专区二：国内 AI 动态 -->
  <section class="zone zone--cn">
    <div class="zone__head">
      <span class="zone__name">国内 AI 动态</span>
      {% if chinese_articles %}
      <span class="zone__count">{{ chinese_articles | length }} 条</span>
      {% endif %}
    </div>
    <div class="zone__articles">
      {% if chinese_articles %}
        {% for article in chinese_articles %}
        <div class="ac">
          <div class="ac__head">
            <span class="ac__imp">{{ article.importance_icon }}</span>
            <a class="ac__title" href="{{ article.url }}" target="_blank" rel="noopener noreferrer">{{ article.title }}</a>
          </div>
          {% if article.og_image %}
          <figure class="ac__figure">
            <img class="ac__cover" src="{{ article.og_image }}" alt="" loading="lazy" onerror="this.parentNode.style.display='none'">
            <figcaption class="ac__date">{{ article.pub_date_str or "发布日期未知" }}</figcaption>
          </figure>
          {% else %}
          <div class="ac__date ac__date--solo">{{ article.pub_date_str or "发布日期未知" }}</div>
          {% endif %}
          {% if article.key_points %}
          <ul class="ac__points">
            {% for p in article.key_points %}<li>{{ p }}</li>{% endfor %}
          </ul>
          {% endif %}
          {% if article.ai_summary %}<p class="ac__summary">{{ article.ai_summary }}</p>{% endif %}
          <div class="ac__meta">
            <span class="ac__source">{{ article.source }}</span>
            {% for tag in article.tags %}{% if tag in article._link_colors %}<span class="ac__tag" style="background:{{ article._link_colors[tag] }}">{{ tag }}</span>{% endif %}{% endfor %}
          </div>
        </div>
        {% endfor %}
      {% else %}
        <p class="zone__empty">暂无国内 AI 动态</p>
      {% endif %}
    </div>
  </section>

  <!-- ▸ 专区三：全球 AI 大事件 -->
  <section class="zone zone--global">
    <div class="zone__head">
      <span class="zone__name">全球 AI 大事件</span>
      {% if global_articles %}
      <span class="zone__count">{{ global_articles | length }} 条</span>
      {% endif %}
    </div>
    <div class="zone__articles">
      {% if global_articles %}
        {% for article in global_articles %}
        <div class="ac">
          <div class="ac__head">
            <span class="ac__imp">{{ article.importance_icon }}</span>
            <a class="ac__title" href="{{ article.url }}" target="_blank" rel="noopener noreferrer">{{ article.title }}</a>
          </div>
          {% if article.og_image %}
          <figure class="ac__figure">
            <img class="ac__cover" src="{{ article.og_image }}" alt="" loading="lazy" onerror="this.parentNode.style.display='none'">
            <figcaption class="ac__date">{{ article.pub_date_str or "发布日期未知" }}</figcaption>
          </figure>
          {% else %}
          <div class="ac__date ac__date--solo">{{ article.pub_date_str or "发布日期未知" }}</div>
          {% endif %}
          {% if article.key_points %}
          <ul class="ac__points">
            {% for p in article.key_points %}<li>{{ p }}</li>{% endfor %}
          </ul>
          {% endif %}
          {% if article.ai_summary %}<p class="ac__summary">{{ article.ai_summary }}</p>{% endif %}
          <div class="ac__meta">
            <span class="ac__source">{{ article.source }}</span>
            {% for tag in article.tags %}{% if tag in article._link_colors %}<span class="ac__tag" style="background:{{ article._link_colors[tag] }}">{{ tag }}</span>{% endif %}{% endfor %}
          </div>
        </div>
        {% endfor %}
      {% else %}
        <p class="zone__empty">暂无全球 AI 大事件</p>
      {% endif %}
    </div>
  </section>

  <!-- ▸ 温故知新 -->
  {% if lookback_html %}
  <section class="lookback">
    <div class="lookback__label">温故知新</div>
    {{ lookback_html }}
  </section>
  {% endif %}

